<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="420.0" prefWidth="600.0" spacing="8.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.practicaexamenu3.controllers.AppController">
   <children>
      <Label fx:id="lblMsg" text="Registro de contactos de emergencia" />
      <GridPane hgap="10.0" vgap="6.0">
        <columnConstraints>
          <ColumnConstraints hgrow="NEVER" minWidth="100.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Nombre" />
            <TextField fx:id="txtName" GridPane.columnIndex="1" />
            <Label text="Teléfono" GridPane.rowIndex="1" />
            <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Parentesco" GridPane.rowIndex="2" />
            <ComboBox fx:id="cmbParentesco" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <HBox prefHeight="35.0" prefWidth="200.0" spacing="5.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onAgregar" text="Agregar" />
            <Button mnemonicParsing="false" onAction="#onBuscar" text="Buscar" />
            <Button mnemonicParsing="false" onAction="#onActualizar" text="Actualizar" />
            <Button mnemonicParsing="false" onAction="#onEliminar" text="Eliminar" />
            <Button mnemonicParsing="false" onAction="#onLimpiar" text="Limpiar" />
         </children>
      </HBox>
      <ListView fx:id="listView" prefHeight="200.0" prefWidth="200.0" />
   </children>
</VBox>